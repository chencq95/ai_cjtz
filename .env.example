# Copy this file to .env and adjust values for the target environment.
# Every application setting uses the DMP_ prefix.

DMP_ENVIRONMENT=development
DMP_DATABASE_URL=sqlite:///data/catalog.db
DMP_REDIS_URL=redis://127.0.0.1:6379/0
DMP_OBJECT_STORE_BACKEND=filesystem
DMP_OBJECT_STORE_PATH=data/raw
DMP_ARCHIVE_PATH=data/archive
DMP_RAW_RETENTION_DAYS=365
DMP_MINIO_ENDPOINT=127.0.0.1:9000
DMP_MINIO_ACCESS_KEY=minioadmin
DMP_MINIO_SECRET_KEY=minioadmin
DMP_MINIO_BUCKET=data-market-raw
DMP_MINIO_SECURE=false
DMP_TIMEZONE=Asia/Shanghai

# Daily crawl time in DMP_TIMEZONE.
DMP_SCHEDULE_HOUR=2
DMP_SCHEDULE_MINUTE=30

# Crawl safety and capacity limits.
DMP_CRAWL_CONCURRENCY=8
DMP_PLATFORM_CONCURRENCY=4
DMP_REQUEST_TIMEOUT_SECONDS=30
DMP_CONNECT_TIMEOUT_SECONDS=10
DMP_RATE_LIMIT_REQUESTS_PER_SECOND=1
DMP_MAX_PAGES_PER_PLATFORM=1000
DMP_MAX_CRAWL_DEPTH=8
DMP_MAX_RETRIES=3
DMP_RETRY_BACKOFF_SECONDS=2
DMP_MAX_RESPONSE_BYTES=15000000
DMP_ENABLE_BROWSER=true
DMP_BROWSER_TIMEOUT_SECONDS=45
DMP_BROWSER_SETTLE_MILLISECONDS=1500
DMP_BROWSER_PAGINATION_ENABLED=true
DMP_BROWSER_MAX_PAGINATION_PAGES=300
DMP_INCREMENTAL_OVERLAP_DAYS=3
DMP_FULL_RECHECK_DAYS=30
DMP_CLASSIFICATION_REVIEW_THRESHOLD=0.80
DMP_RESPECT_ROBOTS_TXT=true
DMP_VERIFY_TLS=true

# HTTP identity and API service.
DMP_USER_AGENT=DataMarketProbe/0.1 (+https://localhost)
DMP_API_HOST=127.0.0.1
DMP_API_PORT=8000
DMP_API_RELOAD=false
DMP_API_CORS_ORIGINS=http://127.0.0.1:8080,http://localhost:8080
DMP_AUTH_SECRET_KEY=replace-with-at-least-32-random-characters
DMP_AUTH_TOKEN_MINUTES=480
DMP_BOOTSTRAP_ADMIN_USERNAME=admin
DMP_BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!
DMP_COOKIE_SECURE=false
DMP_CELERY_EAGER=false
DMP_SCHEDULER_POLL_SECONDS=60
DMP_LOG_LEVEL=INFO
